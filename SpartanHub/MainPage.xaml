<Page
    x:Class="SpartanHub.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SpartanHub"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <StackPanel
        MaxWidth="800"
        Padding="20"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="15">
        <TextBlock
            HorizontalAlignment="Center"
            FontSize="32"
            FontWeight="Bold"
            Text="SpartanHub - 光环无限战绩查询" />

        <TextBlock
            Margin="0,20,0,0"
            HorizontalAlignment="Center"
            FontSize="18"
            Foreground="Gray"
            Text="欢迎来到 UNSC 指挥终端" />

        <Button
            Margin="0,30,0,0"
            Padding="20,10"
            HorizontalAlignment="Center"
            Click="NavigateToAuthPage_Click"
            Content="登录 HaloWaypoint" />
        <Button
            Margin="0,2,0,0"
            Padding="20,10"
            HorizontalAlignment="Center"
            Click="NavigateToDevPage_Click"
            Content="进入开发测试页面" />
        <Button
            Margin="0,2,0,0"
            Padding="20,10"
            HorizontalAlignment="Center"
            Click="NavigateToControlTestPage_Click"
            Content="进入控件测试页面" />
        <Button
            Margin="0,2,0,0"
            Padding="20,10"
            HorizontalAlignment="Center"
            Click="NavigateToHomePage_Click"
            Content="进入主页" />
    </StackPanel>
</Page>
