<UserControl
    x:Class="SpartanHub.Controls.SessionCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SpartanHub.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="126"
    d:DesignWidth="495"
    mc:Ignorable="d">

    <Grid
        Width="495"
        Height="126"
        BorderBrush="Gray"
        BorderThickness="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Image Grid.ColumnSpan="2" Source="/Assets/SessionCardBackground.png" />
        <Border
            Width="100"
            Height="64"
            Margin="28,0,28,0"
            HorizontalAlignment="Left"
            Background="#162024">
            <TextBlock
                x:Name="RankTextBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="38"
                Text="46" />
        </Border>
        <Grid
            Grid.Column="1"
            Margin="0,0,28,0"
            VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="TrackNameTextBlock"
                FontSize="24"
                Text="INFINITE" />
            <ProgressBar
                x:Name="RankProgressBar"
                Grid.Row="1"
                Margin="0,4,0,4"
                Foreground="White"
                Value="10" />
            <TextBlock
                x:Name="CurrentXpTextBlock"
                Grid.Row="2"
                HorizontalAlignment="Left"
                Text="1000XP" />
            <TextBlock
                x:Name="RemainingXpTextBlock"
                Grid.Row="2"
                HorizontalAlignment="Right"
                Text="1000XP" />
        </Grid>
    </Grid>
</UserControl>
