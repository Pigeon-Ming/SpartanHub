<Page
    x:Class="SpartanHub.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SpartanHub.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SpartanHub.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary Source="/Dictionaries/MatchStatsResources.xaml" />
    </Page.Resources>
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <controls:PlayerInfoNameplateControl x:Name="MyNameplateControl"/>
        <TextBlock Grid.Row="1" Text="总览 Summary" Style="{ThemeResource SubheaderTextBlockStyle}" Margin="8,0,0,0"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <controls:LabeledControl Label="总场数">
                <TextBlock Text="1056" />
            </controls:LabeledControl>
            <controls:LabeledControl Label="通行证等级">
                <TextBlock Text="376" />
            </controls:LabeledControl>
            <controls:LabeledControl Label="总击杀数">
                <TextBlock Text="11542" />
            </controls:LabeledControl>
            <controls:LabeledControl Label="时长">
                <TextBlock Text="6天16时5分" />
            </controls:LabeledControl>
        </StackPanel>
        <Grid Grid.Row="3">
            <Grid.Resources>
                <Style TargetType="Button" x:Key="TransparentButton">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <controls:LabeledControl Label="赛季">
                <Button Style="{ThemeResource TransparentButton}">
                    <controls:SessionCardControl HorizontalAlignment="Left" />
                </Button>
            </controls:LabeledControl>
            <controls:LabeledControl Grid.Column="1" Label="最近比赛">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Button HorizontalAlignment="Stretch" Style="{ThemeResource TransparentButton}">
                        <ContentPresenter Name="RecentMatchStatsItem" ContentTemplate="{StaticResource MatchStatsItemTemplate}" />
                    </Button>
                    <Button Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock>查看近20条数据</TextBlock>
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72A;" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </controls:LabeledControl>
        </Grid>
    </Grid>
</Page>
