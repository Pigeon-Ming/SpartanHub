<Page
    x:Class="SpartanHub.Views.ControlTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SpartanHub.Controls"
    xmlns:converters="using:SpartanHub.Modals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SpartanHub.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SpartanHub.Core.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:MatchOutcomeToColorConverter x:Key="MatchOutcomeToColorConverter" />
        <DataTemplate x:Name="MatchStatsItemTemplate" x:DataType="models:MatchStats">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="4"
                    Margin="0,4,4,4"
                    Background="{x:Bind Teams[0].Outcome, Converter={StaticResource MatchOutcomeToColorConverter}}" />
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        FontSize="20"
                        FontWeight="Medium"
                        Text="{Binding MatchInfo.MapId}" />
                    <TextBlock Grid.Row="1" Text="{Binding MatchInfo.MapModePairId}" />
                    <TextBlock Grid.Row="2" Text="1 Kills 1 Deaths 5 Assists" />
                </Grid>
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="200:150" />
            </Grid>
        </DataTemplate>
    </Page.Resources>
    <Grid>
        <StackPanel>
            <controls:PlayerInfoNameplateControl />
            <controls:SessionCardControl />
            <ContentPresenter
                Width="400"
                Content="{x:Bind matchStats}"
                ContentTemplate="{x:Bind MatchStatsItemTemplate, Mode=OneWay}" />
            <StackPanel Orientation="Horizontal">
                <controls:LabeledControl Label="总场数">
                    <Grid>
                        <TextBlock Text="1056" />
                    </Grid>
                </controls:LabeledControl>
                <controls:LabeledControl Label="通行证等级">
                    <Grid>
                        <TextBlock>
                            376
                        </TextBlock>
                    </Grid>
                </controls:LabeledControl>
                <controls:LabeledControl Label="时长">
                    <Grid>
                        <TextBlock>
                            6天16时5分
                        </TextBlock>
                    </Grid>
                </controls:LabeledControl>
                <controls:LabeledControl Label="总击杀数">
                    <Grid>
                        <TextBlock>
                            11542
                        </TextBlock>
                    </Grid>
                </controls:LabeledControl>


            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
