<Page
    x:Class="SpartanHub.DevPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SpartanHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="15" MaxWidth="800" HorizontalAlignment="Stretch">
            <TextBlock Text="SpartanHub - 光环无限战绩查询" FontSize="28" FontWeight="Bold" />
            
            <TextBlock Text="测试API功能" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="GamerTagTextBox" 
                         Header="输入GamerTag" 
                         MaxWidth="300"
                         PlaceholderText="例如: GravlLift" />
                <Button x:Name="QueryButton" 
                        Content="查询" 
                        VerticalAlignment="Bottom" 
                        Click="QueryButton_Click" />
            </StackPanel>

            <ProgressRing x:Name="LoadingRing" 
                         IsActive="False" 
                         Width="50" 
                         Height="50" 
                         HorizontalAlignment="Left" />

            <TextBlock x:Name="StatusText" 
                      Text="" 
                      Foreground="Gray" 
                      TextWrapping="Wrap" />

            <Border x:Name="ResultBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="查询结果" FontSize="20" FontWeight="SemiBold" />
                    
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <Image x:Name="GamerPicImage" 
                               Width="64" 
                               Height="64" 
                               Stretch="UniformToFill" />
                        <StackPanel>
                            <TextBlock x:Name="GamertagResult" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="XuidResult" Foreground="Gray" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="对战历史" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="MatchHistoryXuidTextBox" 
                         Header="输入XUID" 
                         MaxWidth="300"
                         PlaceholderText="玩家XUID" />
                <Button x:Name="MatchHistoryButton" 
                        Content="查询对战历史" 
                        VerticalAlignment="Bottom" 
                        Click="MatchHistoryButton_Click" />
            </StackPanel>

            <ListView x:Name="MatchHistoryList" 
                      MaxHeight="300" 
                      Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding MatchId}" FontWeight="SemiBold" Width="200" />
                            <TextBlock Text="{Binding Outcome}" Width="100" />
                            <TextBlock Text="{Binding MatchInfo.MapId}" Width="150" />
                            <Button Content="详细" Click="MatchStatsButton_Click" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Text="单场比赛详细数据" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="MatchIdTextBox" 
                         Header="输入MatchId" 
                         MaxWidth="400"
                         PlaceholderText="比赛ID" />
                <Button x:Name="MatchStatsButton" 
                        Content="查询比赛数据" 
                        VerticalAlignment="Bottom" 
                        Click="MatchStatsButton_Click" />
            </StackPanel>

            <Border x:Name="MatchStatsBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="5">
                    <TextBlock Text="比赛统计" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock x:Name="MatchStatsResult" 
                               TextWrapping="Wrap" 
                               FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <TextBlock Text="CSR段位信息" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="CsrXuidTextBox" 
                         Header="输入XUID" 
                         MaxWidth="200"
                         PlaceholderText="玩家XUID" />
                <TextBox x:Name="CsrPlaylistIdTextBox" 
                         Header="输入PlaylistId" 
                         MaxWidth="200"
                         PlaceholderText="玩法ID" />
                <Button x:Name="CsrQueryButton" 
                        Content="查询CSR" 
                        VerticalAlignment="Bottom" 
                        Click="CsrQueryButton_Click" />
            </StackPanel>

            <Border x:Name="CsrResultBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="5">
                    <TextBlock x:Name="CsrResult" 
                               TextWrapping="Wrap" 
                               FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <TextBlock Text="战绩记录" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="ServiceRecordTextBox" 
                         Header="输入GamerTag" 
                         MaxWidth="300"
                         PlaceholderText="玩家GamerTag" />
                <Button x:Name="ServiceRecordButton" 
                        Content="查询战绩记录" 
                        VerticalAlignment="Bottom" 
                        Click="ServiceRecordButton_Click" />
            </StackPanel>

            <Border x:Name="ServiceRecordBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="5">
                    <TextBlock x:Name="ServiceRecordResult" 
                               TextWrapping="Wrap" 
                               FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <TextBlock Text="对战隐私设置" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="PrivacyXuidTextBox" 
                         Header="输入XUID" 
                         MaxWidth="300"
                         PlaceholderText="玩家XUID" />
                <Button x:Name="PrivacyGetButton" 
                        Content="获取隐私" 
                        VerticalAlignment="Bottom" 
                        Click="PrivacyGetButton_Click" />
                <Button x:Name="PrivacySetButton" 
                        Content="设置为显示" 
                        VerticalAlignment="Bottom" 
                        Click="PrivacySetButton_Click" />
            </StackPanel>

            <Border x:Name="PrivacyResultBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="5">
                    <TextBlock x:Name="PrivacyResult" 
                               TextWrapping="Wrap" 
                               FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <TextBlock Text="封禁查询" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="BanXuidTextBox" 
                         Header="输入XUID" 
                         MaxWidth="300"
                         PlaceholderText="玩家XUID" />
                <Button x:Name="BanQueryButton" 
                        Content="查询封禁" 
                        VerticalAlignment="Bottom" 
                        Click="BanQueryButton_Click" />
            </StackPanel>

            <Border x:Name="BanResultBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="5">
                    <TextBlock x:Name="BanResult" 
                               TextWrapping="Wrap" 
                               FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <TextBlock Text="勋章元数据" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="MedalsButton" 
                        Content="获取勋章列表" 
                        Click="MedalsButton_Click" />
            </StackPanel>

            <Border x:Name="MedalsResultBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="5">
                    <TextBlock x:Name="MedalsResult" 
                               TextWrapping="Wrap" 
                               FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <TextBlock Text="赛季信息" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="SeasonButton" 
                        Content="获取赛季日历" 
                        Click="SeasonButton_Click" />
                <Button x:Name="CsrSeasonButton" 
                        Content="获取CSR赛季" 
                        Click="CsrSeasonButton_Click" />
            </StackPanel>

            <Border x:Name="SeasonResultBorder" 
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                    BorderThickness="1" 
                    Padding="15" 
                    Visibility="Collapsed">
                <StackPanel Spacing="5">
                    <TextBlock x:Name="SeasonResult" 
                               TextWrapping="Wrap" 
                               FontFamily="Consolas" />
                </StackPanel>
            </Border>

            <TextBlock Text="测试Spartan Token" FontSize="18" Margin="0,10,0,0" />
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox x:Name="TokenTextBox" 
                         Header="输入Spartan Token" 
                         MaxWidth="500"
                         PlaceholderText="输入你的Spartan Token用于认证测试" />
                <Button x:Name="SetTokenButton" 
                        Content="设置Token" 
                        VerticalAlignment="Bottom" 
                        Click="SetTokenButton_Click" />
            </StackPanel>

            <TextBlock Text="使用说明" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray">
                1. 首先需要获取Spartan Token（通过Xbox Live认证流程）<LineBreak/>
                2. 输入GamerTag查询玩家信息<LineBreak/>
                3. 对战历史需要XUID，可从用户信息中获取<LineBreak/>
                4. 比赛数据需要MatchId，可从对战历史中获取
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</Page>
